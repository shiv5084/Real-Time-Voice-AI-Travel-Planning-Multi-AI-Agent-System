# =============================================================================
# Local development (Phases 0–6) — use with docker-compose up
# =============================================================================
APP_ENV=local
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travel_db
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Production / staging (Phase 7+ migration) — uncomment and fill when deploying
# =============================================================================
# APP_ENV=production
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-role-key
# UPSTASH_REDIS_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_TOKEN=your-upstash-token
#SUPABASE_DB_PASSWORD=your-database-password

# =============================================================================
# Shared API keys (all environments — add when integrating external services)
# =============================================================================
# GROQ_API_KEY=your_groq_api_key
# GEMINI_API_KEY=your_gemini_api_key
# MEM0_API_KEY=
# AVIATIONSTACK_API_KEY=
# TAVILY_API_KEY=
# ELEVENLABS_API_KEY=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=

# =============================================================================
# Phase 2 — MCP Server (external, configurable — update URL if server moves)
# The URL below is the current deployment. Change MCP_SERVER_URL to migrate.
# =============================================================================
MCP_SERVER_URL=https://multi-mcp-servers.onrender.com
# MCP_RATE_LIMIT_AVIATIONSTACK=60   # requests/minute
# MCP_RATE_LIMIT_TAVILY=100
# MCP_RATE_LIMIT_MAPS=120
# MCP_RATE_LIMIT_GMAIL=30
# CACHE_TTL_FLIGHTS=3600            # 1 hour (seconds)
# CACHE_TTL_ATTRACTIONS=86400       # 24 hours
# CACHE_TTL_GEOCODING=604800        # 7 days
# CACHE_TTL_ROUTES=86400            # 24 hours

# =============================================================================
# Phase 3 — Core Agent Pipeline (LangGraph Orchestration)
# =============================================================================
GROQ_API_KEY=your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key


# LLM model names (configurable)
# GROQ_MODEL_LARGE=llama-3.3-70b-versatile
# GROQ_MODEL_SMALL=llama-3.1-8b-instant
# GEMINI_MODEL=gemini-2.0-flash

# Agent step limits
# AGENT_STEPS_PLANNER=5
# AGENT_STEPS_WORKER=3
# AGENT_STEPS_BUDGET=2
# AGENT_STEPS_COMPOSER=3
# AGENT_STEPS_VALIDATOR=2

# =============================================================================
# Phase 4 — Memory, Personalization & Self-Correcting Loop
# =============================================================================
MEM0_API_KEY=your_mem0_api_key
# Get your key at: https://app.mem0.ai  (free tier available)
# If MEM0_API_KEY is not set, the system uses Redis as a local preference store.


# =============================================================================
# Phase 5 — Voice Pipeline (STT + TTS)
# STT: Groq Whisper API — reuses GROQ_API_KEY above, no local model needed
# =============================================================================
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9          # Jessica (default)
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo          # whisper-large-v3-turbo | whisper-large-v3 | distil-whisper-large-v3-en
# VAD_AGGRESSIVENESS=2                               # 0-3 (higher = more aggressive filtering)
# VAD_SAMPLE_RATE=16000                              # 16000 Hz recommended

# =============================================================================
# Next.js (see frontend/.env.local.example)
# =============================================================================
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
