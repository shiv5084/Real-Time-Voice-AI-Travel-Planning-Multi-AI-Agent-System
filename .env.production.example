# =============================================================================
# Production / Staging Environment (Phase 7A+)
# =============================================================================
# Copy this file to .env and fill in your actual values
# Set APP_ENV=production for production or APP_ENV=staging for staging
# =============================================================================

APP_ENV=production

# =============================================================================
# Managed Services - Supabase (PostgreSQL + Auth)
# =============================================================================
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password

# =============================================================================
# Managed Services - Upstash (Redis)
# =============================================================================
# Get these from your Upstash Redis instance
UPSTASH_REDIS_URL=https://your-instance.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-redis-token

# =============================================================================
# Logging & CORS
# =============================================================================
LOG_LEVEL=INFO
CORS_ORIGINS=https://your-frontend-domain.com,https://your-staging-domain.com

# =============================================================================
# Shared API keys (all environments)
# =============================================================================
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key
MEM0_API_KEY=your-mem0-api-key
AVIATIONSTACK_API_KEY=your-aviationstack-api-key
TAVILY_API_KEY=your-tavily-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret

# =============================================================================
# Phase 2 — MCP Server (external, configurable)
# =============================================================================
MCP_SERVER_URL=https://multi-mcp-servers.onrender.com
MCP_RATE_LIMIT_AVIATIONSTACK=60
MCP_RATE_LIMIT_TAVILY=100
MCP_RATE_LIMIT_MAPS=120
MCP_RATE_LIMIT_GMAIL=30
CACHE_TTL_FLIGHTS=3600            # 1 hour (seconds)
CACHE_TTL_ATTRACTIONS=86400       # 24 hours
CACHE_TTL_GEOCODING=604800        # 7 days
CACHE_TTL_ROUTES=86400            # 24 hours

# =============================================================================
# Phase 3 — Core Agent Pipeline (LangGraph Orchestration)
# =============================================================================
# LLM model names (configurable)
GROQ_MODEL_LARGE=llama-3.3-70b-versatile
GROQ_MODEL_SMALL=llama-3.1-8b-instant
GEMINI_MODEL=gemini-2.0-flash

# Agent step limits
AGENT_STEPS_PLANNER=5
AGENT_STEPS_WORKER=3
AGENT_STEPS_BUDGET=2
AGENT_STEPS_COMPOSER=3
AGENT_STEPS_VALIDATOR=2

# =============================================================================
# Phase 5 — Voice Pipeline (STT + TTS)
# =============================================================================
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9          # Rachel (default)
GROQ_WHISPER_MODEL=whisper-large-v3-turbo          # whisper-large-v3-turbo | whisper-large-v3 | distil-whisper-large-v3-en
VAD_AGGRESSIVENESS=2                               # 0-3 (higher = more aggressive filtering)
VAD_SAMPLE_RATE=16000                              # 16000 Hz recommended
