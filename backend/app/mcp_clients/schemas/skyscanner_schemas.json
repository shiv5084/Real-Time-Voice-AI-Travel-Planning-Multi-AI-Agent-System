{
  "search_flight": {
    "args": {
      "type": "object",
      "properties": {
        "origin": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "pattern": "^[A-Z]{3}$",
          "description": "Origin airport IATA code (e.g., JFK, LHR)"
        },
        "destination": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "pattern": "^[A-Z]{3}$",
          "description": "Destination airport IATA code (e.g., LAX, CDG)"
        },
        "departure_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Departure date in YYYY-MM-DD format"
        },
        "return_date": {
          "type": ["string", "null"],
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Return date in YYYY-MM-DD format (optional)"
        },
        "adults": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9,
          "description": "Number of adult passengers"
        },
        "cabin_class": {
          "type": "string",
          "enum": ["economy", "premium_economy", "business", "first"],
          "description": "Cabin class (optional)"
        }
      },
      "required": ["origin", "destination", "departure_date"],
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error"]
        },
        "origin": {
          "type": "string"
        },
        "destination": {
          "type": "string"
        },
        "departure_date": {
          "type": "string"
        },
        "return_date": {
          "type": ["string", "null"]
        },
        "results_count": {
          "type": "integer"
        },
        "data": {
          "type": "array"
        },
        "message": {
          "type": "string"
        }
      },
      "required": ["status"],
      "additionalProperties": true
    }
  }
}
