{
  "google_maps_geocode": {
    "args": {
      "type": "object",
      "properties": {
        "address": {
          "type": "string",
          "minLength": 2,
          "description": "Address or city to geocode"
        }
      },
      "required": ["address"],
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error"]
        },
        "data": {
          "type": "object",
          "properties": {
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "formatted_address": {"type": "string"},
                  "geometry": {
                    "type": "object",
                    "properties": {
                      "location": {
                        "type": "object",
                        "properties": {
                          "lat": {"type": "number"},
                          "lng": {"type": "number"}
                        },
                        "required": ["lat", "lng"]
                      }
                    },
                    "required": ["location"]
                  }
                },
                "required": ["formatted_address", "geometry"]
              }
            },
            "status": {"type": "string"}
          },
          "required": ["results", "status"]
        },
        "source": {"type": "string"}
      },
      "required": ["status"],
      "additionalProperties": true
    }
  },
  "google_maps_directions": {
    "args": {
      "type": "object",
      "properties": {
        "origin": {
          "type": "string",
          "minLength": 2,
          "description": "Starting location address or city"
        },
        "destination": {
          "type": "string",
          "minLength": 2,
          "description": "Destination location address or city"
        },
        "mode": {
          "type": "string",
          "enum": ["driving", "walking", "bicycling", "transit"],
          "default": "driving",
          "description": "Travel mode"
        }
      },
      "required": ["origin", "destination"],
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error"]
        },
        "data": {
          "type": "object",
          "properties": {
            "routes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "legs": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "startLocation": {
                          "type": "object",
                          "properties": {
                            "latLng": {
                              "type": "object",
                              "properties": {
                                "latitude": {"type": "number"},
                                "longitude": {"type": "number"}
                              },
                              "required": ["latitude", "longitude"]
                            }
                          },
                          "required": ["latLng"]
                        },
                        "endLocation": {
                          "type": "object",
                          "properties": {
                            "latLng": {
                              "type": "object",
                              "properties": {
                                "latitude": {"type": "number"},
                                "longitude": {"type": "number"}
                              },
                              "required": ["latitude", "longitude"]
                            }
                          },
                          "required": ["latLng"]
                        },
                        "steps": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "navigationInstruction": {
                                "type": "object",
                                "properties": {
                                  "instruction": {"type": "string"}
                                },
                                "required": ["instruction"]
                              }
                            },
                            "required": ["navigationInstruction"]
                          }
                        }
                      },
                      "required": ["startLocation", "endLocation", "steps"]
                    }
                  },
                  "distanceMeters": {"type": "number"},
                  "duration": {"type": "string"},
                  "localizedValues": {
                    "type": "object",
                    "properties": {
                      "distance": {
                        "type": "object",
                        "properties": {
                          "text": {"type": "string"}
                        },
                        "required": ["text"]
                      },
                      "duration": {
                        "type": "object",
                        "properties": {
                          "text": {"type": "string"}
                        },
                        "required": ["text"]
                      }
                    },
                    "required": ["distance", "duration"]
                  }
                },
                "required": ["legs", "distanceMeters", "duration", "localizedValues"]
              }
            }
          },
          "required": ["routes"]
        },
        "source": {"type": "string"}
      },
      "required": ["status"],
      "additionalProperties": true
    }
  }
}
